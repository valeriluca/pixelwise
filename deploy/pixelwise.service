[Unit]
Description=PixelWise API
After=network.target

[Service]
User=produser
WorkingDirectory=/home/produser/pixelwise
EnvironmentFile=/home/produser/pixelwise/.env
ExecStart=/home/produser/pixelwise/.venv/bin/uvicorn \
    app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
